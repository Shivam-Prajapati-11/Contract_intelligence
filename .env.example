# Contract Intelligence Platform — Environment Configuration
# Copy this file to .env and adjust values for your hardware.

# ── LLM Provider ──
# Choose: "groq" (free API, no GPU) or "ollama" (local, GPU)
LLM_PROVIDER=groq

# When using Groq (free): get your API key at https://console.groq.com
# They give free access to Llama 3 70B, Mixtral 8x7B, etc.
LLM_API_KEY=
LLM_MODEL=llama3-70b-8192
# Other free Groq models: "llama3-8b-8192", "mixtral-8x7b-32768", "gemma2-9b-it"

# When using Ollama (local), configure these:
# OLLAMA_URL=http://127.0.0.1:11434/api/generate
# OLLAMA_MODEL=qwen2.5:7b
# OLLAMA_TEMPERATURE=0.0
# OLLAMA_MAX_TOKENS=1024
# OLLAMA_TIMEOUT=120
# OLLAMA_SEED=42
# OLLAMA_NUM_CTX=16384

# ── Redis ──
REDIS_URL=redis://localhost:6379/0

# ── Qdrant (Vector Database) ──
# Set URL for remote Qdrant server, or leave empty for in-memory (local mode)
QDRANT_URL=http://localhost:6333
# QDRANT_LOCAL_PATH=./data/qdrant  # Uncomment for persistent local storage

# ── Embedding Model ──
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu

# ── OCR Engine (PaddleOCR) ──
# OCR is CPU-only by default. GPU requires PaddleOCR with CUDA installed.
OCR_USE_GPU=false
OCR_CPU_THREADS=4
OCR_ENABLE_MKLDNN=true
OCR_DPI=300

# ── Chunking ──
CHUNK_MAX_CHARS=1200
CHUNK_OVERLAP=200

# ── Retrieval ──
SEARCH_TOP_K=15
MAX_CONTEXT_CHARS=12000
PREAMBLE_CHUNKS=10

# ── Upload ──
MAX_FILE_SIZE_MB=50
UPLOAD_DIR=data/uploads

# ── App ──
DEBUG=false